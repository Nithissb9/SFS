function showModal(k){
  const d=D[k],isPkg=k.startsWith('pkg_');
  const timelineHtml=isPkg?`<div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;font-size:13px;color:#7b7a99">⏱ ${d.timeline}</div>`:'';
  const benefitHtml=!isPkg?`<div class="mbenefit">✅ ${d.benefit}</div>`:'';
  document.getElementById('mbox').innerHTML=`
    <div class="mhead">
      <span class="mi">${d.icon}</span>
      <h3>${d.title}</h3>
      <button class="mclose" onclick="closeModal()" aria-label="ปิด">✕</button>
    </div>
    <div class="mbody">
      <p class="mdesc">${d.desc}</p>
      ${timelineHtml}${benefitHtml}
      <div class="mlist-title">${isPkg?'รายการที่รวมอยู่':'ฟีเจอร์หลัก'}</div>
      <ul class="mlist">${d.items.map(i=>`<li><span class="ck">✓</span>${i}</li>`).join('')}</ul>
      <a href="https://m.me/naiball.nithis.2025" target="_blank" rel="noopener" class="mcta" style="background:${d.accent};color:#fff;display:block;text-decoration:none">สอบถาม ${d.title} ทาง Messenger →</a>
    </div>`;
  document.getElementById('ov').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){
  document.getElementById('ov').classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal()});
document.querySelectorAll('.pcard[role=button]').forEach(el=>{
  el.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' ')el.click()});
});
</script>
