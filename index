<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Factory Solution — ระบบโรงงานอัจฉริยะ</title>
<meta name="description" content="พัฒนาระบบโรงงาน Dashboard, CMMS, Traceability โดยผู้มีประสบการณ์จริงในโรงงาน">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:#0d0d1a;color:#f0eeff;font-family:'Segoe UI',Tahoma,sans-serif;line-height:1.6}
a{text-decoration:none}

/* HERO */
.hero{text-align:center;padding:4rem 1.5rem 3rem;background:radial-gradient(ellipse at 50% 0%,#1a1030 0%,#0d0d1a 70%)}
.chip{display:inline-block;font-size:11px;font-weight:700;letter-spacing:3px;padding:6px 18px;border-radius:20px;background:#6c47ff22;color:#9b82ff;border:1px solid #6c47ff55;margin-bottom:1.25rem}
.hero h1{font-size:clamp(22px,4vw,36px);font-weight:700;color:#f0eeff;line-height:1.35;margin-bottom:.75rem}
.hero h1 span{color:#6c47ff}
.hero p{font-size:15px;color:#7b7a99;max-width:520px;margin:0 auto 2rem}
.hero-cta{display:inline-flex;align-items:center;gap:10px;background:#6c47ff;color:#fff;font-size:15px;font-weight:600;padding:.75rem 2rem;border-radius:12px;transition:background .2s}
.hero-cta:hover{background:#7d5bff}
.hero-cta svg{width:18px;height:18px;fill:currentColor}

/* SECTIONS */
.section{padding:3rem 1.5rem;max-width:900px;margin:0 auto}
.sec-label{font-size:11px;font-weight:700;letter-spacing:3px;color:#6c47ff;text-align:center;margin-bottom:1.25rem;text-transform:uppercase}
.divider{height:1px;background:#2a2a44;max-width:900px;margin:0 auto}

/* PAIN */
.pain-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px}
.pain-item{background:#1a1a2e;border:1px solid #2a2a44;border-radius:10px;padding:.85rem 1rem;font-size:13px;color:#9b8fc0;display:flex;align-items:center;gap:10px}
.pain-item .dot{width:6px;height:6px;border-radius:50%;background:#ff6b6b;flex-shrink:0}

/* MODULES */
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px}
.fcard{background:#1a1a2e;border:1px solid #2a2a44;border-top-width:3px;border-radius:14px;padding:1.25rem;cursor:pointer;transition:all .2s;text-align:left;width:100%}
.fcard:hover{transform:translateY(-3px);background:#201a38}
.fcard .fi{font-size:28px;margin-bottom:.75rem;display:block}
.fcard .ft{font-size:13px;font-weight:700;color:#f0eeff;margin-bottom:4px}
.fcard .fs{font-size:11px;color:#7b7a99}
.fcard.c1{border-top-color:#6c47ff}
.fcard.c2{border-top-color:#00d4aa}
.fcard.c3{border-top-color:#378add}
.fcard.c4{border-top-color:#ffb347}
.fcard.c5{border-top-color:#ff6b9d}

/* STATS */
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px}
.scard{background:#1a1a2e;border:1px solid #2a2a44;border-radius:12px;padding:1.5rem;text-align:center}
.snum{font-size:30px;font-weight:700}
.slabel{font-size:12px;color:#7b7a99;margin-top:6px}

/* PACKAGES */
.pkg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px}
.pcard{background:#1a1a2e;border:1px solid #2a2a44;border-radius:16px;padding:1.5rem;cursor:pointer;transition:all .2s}
.pcard:hover{transform:translateY(-3px)}
.pcard.featured{border:2px solid #00d4aa;background:#0d2420}
.pcard.ent{border-color:#ffb34766}
.rec-pill{display:inline-block;font-size:10px;font-weight:700;padding:3px 12px;border-radius:20px;background:#00d4aa22;color:#00d4aa;border:1px solid #00d4aa55;margin-bottom:.6rem}
.pname{font-size:16px;font-weight:700;margin-bottom:.4rem}
.plist{font-size:12px;color:#9b8fc0;line-height:2.1;margin-bottom:1rem}
.ptag{display:inline-block;font-size:10px;padding:4px 12px;border-radius:20px;background:#ffffff0f;color:#7b7a99}

/* WHY */
.why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px}
.why-item{background:#1a1a2e;border:1px solid #2a2a44;border-radius:10px;padding:1rem 1.25rem;display:flex;align-items:center;gap:12px;font-size:13px;color:#c0bfdf}
.why-icon{font-size:20px;flex-shrink:0}

/* CTA */
.cta-section{padding:3rem 1.5rem;text-align:center}
.cta-box{background:linear-gradient(135deg,#1a1030,#0d1a2a);border:1px solid #2a2a44;border-radius:20px;padding:3rem 2rem;max-width:580px;margin:0 auto}
.cta-box h2{font-size:22px;font-weight:700;color:#f0eeff;margin-bottom:.75rem}
.cta-box p{font-size:14px;color:#7b7a99;margin-bottom:2rem}
.cta-wrap{display:flex;flex-direction:column;align-items:center;gap:12px}
.btn-fb{display:inline-flex;align-items:center;gap:10px;background:#6c47ff;color:#fff;font-size:15px;font-weight:700;padding:.85rem 2.5rem;border-radius:12px;transition:background .2s}
.btn-fb:hover{background:#7d5bff}
.btn-fb svg{width:20px;height:20px;fill:currentColor}
.btn-line{display:inline-flex;align-items:center;gap:10px;background:#00b900;color:#fff;font-size:14px;font-weight:600;padding:.7rem 2rem;border-radius:12px;transition:opacity .2s}
.btn-line:hover{opacity:.85}
.free-note{font-size:12px;color:#7b7a99;margin-top:.5rem}

/* FOOTER */
footer{text-align:center;padding:1.5rem;border-top:1px solid #2a2a44;font-size:12px;color:#4a4a6a}

/* OVERLAY */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:999;align-items:center;justify-content:center;padding:1rem}
.overlay.open{display:flex}
.modal{background:#16162a;border:1px solid #2a2a44;border-radius:18px;max-width:500px;width:100%;max-height:85vh;overflow-y:auto}
.mhead{padding:1.5rem;border-bottom:1px solid #2a2a44;display:flex;align-items:center;gap:12px;position:sticky;top:0;background:#16162a}
.mhead .mi{font-size:28px}
.mhead h3{font-size:17px;font-weight:700;color:#f0eeff;flex:1}
.mclose{background:none;border:none;color:#7b7a99;font-size:22px;cursor:pointer;padding:4px;line-height:1}
.mbody{padding:1.5rem}
.mdesc{font-size:13px;color:#9b8fc0;line-height:1.8;margin-bottom:1.25rem}
.mbenefit{display:flex;align-items:center;gap:8px;background:#00d4aa11;border:1px solid #00d4aa33;border-radius:8px;padding:.75rem 1rem;margin-bottom:1.25rem;font-size:13px;color:#00d4aa}
.mlist-title{font-size:11px;font-weight:700;color:#7b7a99;letter-spacing:2px;margin-bottom:.6rem}
.mlist{list-style:none}
.mlist li{font-size:13px;color:#9b8fc0;padding:8px 0;display:flex;align-items:center;gap:10px;border-bottom:1px solid #2a2a3a}
.mlist li:last-child{border:none}
.mlist li .ck{color:#00d4aa;font-size:16px;flex-shrink:0}
.mcta{display:block;width:100%;margin-top:1.25rem;padding:.85rem;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;text-align:center;transition:opacity .2s}
.mcta:hover{opacity:.85}

@media(max-width:600px){
  .hero{padding:3rem 1rem 2rem}
  .feat-grid{grid-template-columns:1fr 1fr}
  .pkg-grid{grid-template-columns:1fr}
}
</style>
</head>
